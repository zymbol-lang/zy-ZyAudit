// Test 召模: module-level state, host normalization, binary check, connectivity, model list, existence
// BUG-001 fixed (v0.0.5): 主机 and 临目 are module-level variables — no config tuple needed.

<# ../字审/召模 <= 模

// Default values from module-level variables
>> "主机: " 模::模_主机() ¶
>> "临目: " 模::模_临目() ¶

// Host normalization — 模_设主机 mutates 主机 in-place; 模_主机() reads it back
模::模_设主机("192.168.1.50")
>> "主机（无端口）: " 模::模_主机() ¶

模::模_设主机("192.168.1.50:9999")
>> "主机（有端口）: " 模::模_主机() ¶

模::模_设主机("http://服务器:11434")
>> "主机（完整URL）: " 模::模_主机() ¶

// Restore default for connectivity checks
模::模_设主机("http://localhost:11434")

// Binary presence
已装 = 模::模_已装()
>> "已安装: " 已装 ¶

// Service connectivity — no config param needed
联通 = 模::模_检查()
>> "联通: " 联通 ¶

// Model list and existence — only when Ollama is running
? 联通 {
    列表 = 模::模_列表()
    >> "模型列表: " 列表 ¶

    存在 = 模::模_存在("qwen2.5-coder")
    >> "qwen2.5-coder 已装: " 存在 ¶

    不存在 = 模::模_存在("模型不存在xyz")
    >> "模型不存在xyz 已装: " 不存在 ¶
} _ {
    >> "Ollama 不可达 — 跳过模型检查" ¶
}
