<# ../字审/解析 : 解
<# ../字审/计量 : 量

路径    = "源文件/计算器.zy"
分析   = 解::解_分析文件(路径)
指标   = 量::量_计算全部(分析)

>> "路径:   " 指标.路径   ¶
>> "总行:   " 指标.总行   ¶
>> "代码行: " 指标.代码行 ¶
>> "注释行: " 指标.注释行 ¶
>> "空行:   " 指标.空行   ¶
>> "函数量: " 指标.函数量 ¶
>> "密度:   " 指标.密度   " func/100行" ¶
>> "深度:   " 指标.深度   ¶
>> "复杂度: " 指标.复杂度 ¶
>> "覆盖率: " 指标.覆盖率 ¶
>> "未用:   " (指标.未用$#) " → " ¶
@ 名:指标.未用 { >> "  " 名 ¶ }
