// Test 报告: terminal output and .md generation — ZH / ES / EN

<# ../字审/报告 : 报

// Synthetic metrics tuple — mirrors the shape of 量_计算全部 output
指标 = (
    路径:   "源文件/计算器.zy",
    总行:   "52",
    代码行: "38",
    注释行: "8",
    空行:   "6",
    函数量: 8,
    密度:   "15.38",
    深度:   "3",
    复杂度: "5",
    覆盖率: "75%",
    未用:   ["临时", "_内部辅助"]
)

// Synthetic functions list — mirrors 解_提取函数 output
函列 = [
    (名称: "加法",   行号: "10", 参数量: "2"),
    (名称: "减法",   行号: "11", 参数量: "2"),
    (名称: "乘法",   行号: "12", 参数量: "2"),
    (名称: "除法",   行号: "13", 参数量: "2"),
    (名称: "阶乘",   行号: "18", 参数量: "1"),
    (名称: "幂运算", 行号: "20", 参数量: "2"),
    (名称: "平均值", 行号: "22", 参数量: "1"),
    (名称: "统计",   行号: "25", 参数量: "1")
]

// Synthetic comment blocks
注释列 = [
    "// 功能：将两个数字相加并返回其和\n// 参数：甲: 数字, 乙: 数字\n// 返回：甲 + 乙",
    "// 功能：计算甲减乙的差\n// 参数：甲: 数字, 乙: 数字\n// 返回：甲 - 乙",
    "// 功能：计算两数之积\n// 参数：甲: 数字, 乙: 数字\n// 返回：甲 × 乙",
    "// 功能：安全除法，除数为零时触发错误处理\n// 参数：甲: 数字, 乙: 数字（不为零）\n// 返回：甲 / 乙",
    "// 功能：递归计算 n 的阶乘\n// 参数：n: 非负整数\n// 返回：n!",
    "// 功能：计算甲的乙次幂\n// 参数：甲: 底数, 乙: 指数\n// 返回：甲^乙",
    "// 功能：计算数组元素的平均值\n// 参数：数组: 数字数组\n// 返回：算术平均值",
    "// 功能：汇总数组统计信息\n// 参数：数组: 数字数组\n// 返回：(数量, 和, 均, 最小, 最大)"
]

// --- ZH ---
